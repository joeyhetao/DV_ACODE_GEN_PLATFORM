# ── 数据库 ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dvuser:dvpassword@postgres:5432/dv_platform

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=templates

# ── Embedding Service ────────────────────────────────────────────────────────
EMBEDDING_SERVICE_URL=http://embedding_service:8001

# ── LLM ─────────────────────────────────────────────────────────────────────
# 初始化时写入 llm_configs 表作为默认配置（可为空，之后通过 Admin UI 管理）
ANTHROPIC_API_KEY=

# LLM API Key 数据库加密密钥（必填，32字节十六进制，共 64 个字符）
LLM_KEY_ENCRYPTION_SECRET=change-me-to-a-random-64-hex-char-string-here!!

# ── JWT 认证 ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_EXPIRE_MINUTES=10080

# ── RAG 参数 ─────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.85
RAG_STAGE1_TOP_K=100
RAG_STAGE2_TOP_K=20
RAG_STAGE3_TOP_K=3

# ── 任务队列 ─────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=10

# ── 模板查重 ─────────────────────────────────────────────────────────────────
TEMPLATE_DEDUP_THRESHOLD=0.90

# ── 备份 ─────────────────────────────────────────────────────────────────────
BACKUP_RETAIN_DAYS=7
QDRANT_SNAPSHOT_ENABLED=false

# ── 超管账号（首次启动自动创建）────────────────────────────────────────────────
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change-me-on-first-run
SUPER_ADMIN_EMAIL=admin@example.com
