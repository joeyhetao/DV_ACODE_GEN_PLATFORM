# ═══════════════════════════════════════════════════════════════════════════
# 敏感信息（绝对不能进 git，泄露后即使 force push 历史也可能被扫到）
# ═══════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
*.crt
*.p12
secrets/
credentials*
*-credentials.json

# ═══════════════════════════════════════════════════════════════════════════
# Python 后端（backend/、embedding_service/、lib_manager.py 等）
# ═══════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
*.egg
.installed.cfg

# 测试与质量工具缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ═══════════════════════════════════════════════════════════════════════════
# Node / 前端构建（frontend/）
# ═══════════════════════════════════════════════════════════════════════════
node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/coverage/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ═══════════════════════════════════════════════════════════════════════════
# 运行时数据（Docker volume 之外，本地直接运行时可能产生）
# ═══════════════════════════════════════════════════════════════════════════
backend/uploads/
backend/backups/
*.dump                    # pg_dump 输出
*.sql.gz
*.sqlite
*.sqlite3
*.db

# ═══════════════════════════════════════════════════════════════════════════
# AI 模型与 HuggingFace 缓存（GB 级，绝对不能进 git）
# 离线部署时把模型放到 ./models/，挂载进 embedding_service 容器
# ═══════════════════════════════════════════════════════════════════════════
hf_cache/
.cache/huggingface/
models/
embedding_service/models/

# ═══════════════════════════════════════════════════════════════════════════
# 日志
# ═══════════════════════════════════════════════════════════════════════════
*.log
logs/

# ═══════════════════════════════════════════════════════════════════════════
# IDE / 编辑器
# ═══════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════════════════════
# Claude Code 本地工作文件
# 注意：.claude/agents/ 与 .claude/commands/ 是项目级 skill，应保持追踪
# 仅忽略个人 session memory 和本地权限授予
# ═══════════════════════════════════════════════════════════════════════════
.claude/agent-memory/
.claude/settings.local.json

# ═══════════════════════════════════════════════════════════════════════════
# 操作系统元数据
# ═══════════════════════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ═══════════════════════════════════════════════════════════════════════════
# 临时与备份文件
# ═══════════════════════════════════════════════════════════════════════════
*.tmp
*.temp
*.bak
*.orig

# ═══════════════════════════════════════════════════════════════════════════
